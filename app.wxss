page {
  background: linear-gradient(180deg, #FFF5F5 0%, #FFE4E1 100%);
  min-height: 100vh;
}

.container {
  padding: 20rpx;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 105, 180, 0.1);
}

.btn-primary {
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.btn-secondary {
  background: #FFF0F5;
  color: #FF69B4;
  border: 2rpx solid #FFB6C1;
  border-radius: 40rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.input-field {
  background: #FFF5F5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #FFE4E1;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 600;
}

.badge {
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  color: #FFFFFF;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  position: absolute;
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 14rpx;
  background: #FFF5F5;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.schedule-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 36rpx;
}

.schedule-info {
  flex: 1;
}

.schedule-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.schedule-time {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.wave {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 120rpx;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.floating {
  animation: float 3s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.pulse {
  animation: pulse 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.bounce {
  animation: bounce 1s ease-in-out infinite;
}