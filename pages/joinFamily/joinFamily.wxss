.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFE4E1 100%);
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

.header {
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #FF69B4;
  margin-right: 20rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.form-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(255, 105, 180, 0.15);
}

.invite-code-section {
  text-align: center;
  margin-bottom: 40rpx;
}

.invite-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 30rpx;
  display: block;
}

.code-inputs {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.code-input {
  width: 80rpx;
  height: 80rpx;
  background: #FFF5F5;
  border: 3rpx solid #FFE4E1;
  border-radius: 16rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #FF69B4;
  text-transform: uppercase;
}

.code-input:focus {
  border-color: #FF69B4;
  outline: none;
}

.code-actions {
  margin-bottom: 20rpx;
}

.paste-btn {
  font-size: 26rpx;
  color: #FF69B4;
  text-decoration: underline;
}

.code-tip {
  font-size: 24rpx;
  color: #999999;
}

.join-btn {
  padding: 28rpx;
  font-size: 32rpx;
}

.tips-card {
  margin-top: 30rpx;
  background: #FFF0F5;
  border-radius: 20rpx;
  padding: 24rpx;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #FF69B4;
  display: block;
  margin-bottom: 12rpx;
}

.tips-content {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
}

