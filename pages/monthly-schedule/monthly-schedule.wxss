.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFE4E1 100%);
  padding-bottom: 120rpx;
}

.header-section {
  padding: 30rpx 32rpx;
}

.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.nav-btn {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.month-title-wrap {
  flex: 1;
  text-align: center;
}

.month-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.stats-bar {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.stat-num.completed {
  color: #FF69B4;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.stat-divider {
  width: 2rpx;
  height: 40rpx;
  background: #FFE4E1;
}

.calendar-wrapper {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.week-header {
  display: flex;
  margin-bottom: 16rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 12rpx 0;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.day-cell {
  aspect-ratio: 1;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
  position: relative;
}

.day-cell.other-month {
  opacity: 0.3;
}

.day-cell.today {
  background: linear-gradient(135deg, #FFE4E1 0%, #FFB5C5 100%);
}

.day-cell.selected {
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
}

.day-cell.selected .day-num {
  color: #fff;
}

.day-num {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.day-schedules {
  display: flex;
  gap: 4rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.mini-schedule {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
}

.selected-day-section {
  margin: 24rpx 24rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.day-schedules-list {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.schedule-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #FFF5F5;
  border-radius: 20rpx;
}

.schedule-card:last-child {
  margin-bottom: 0;
}

.schedule-card.completed {
  opacity: 0.6;
}

.schedule-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
}

.schedule-info {
  flex: 1;
}

.schedule-title {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.schedule-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.schedule-check {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #FF69B4;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FF69B4;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

