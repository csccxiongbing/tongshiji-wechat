page {
  background: #f5f7fa;
  min-height: 100vh;
}

.container {
  padding: 0;
  min-height: 100vh;
  background: #f5f7fa;
}

.filter-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.filter-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  padding: 0 8rpx;
}

.filter-item:first-child {
  padding-left: 0;
}

.filter-item:last-child {
  padding-right: 0;
}

.filter-icon {
  font-size: 32rpx;
}

.picker-box {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  border: 2rpx solid #e8eaed;
  transition: all 0.2s ease;
}

.picker-box:active {
  background: #eef0f3;
}

.picker-text {
  font-size: 24rpx;
  color: #2c3e50;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
  margin-left: 8rpx;
}

.stats-summary {
  background: #fff;
  padding: 32rpx;
  margin: 0 0 24rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.summary-item {
  text-align: center;
  flex: 1;
}

.summary-icon {
  font-size: 44rpx;
  display: block;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #FF69B4;
  display: block;
  margin-bottom: 4rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
}

.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 30rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f2f5;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx;
  margin-top: 16rpx;
}

.load-more-text {
  font-size: 26rpx;
  color: #ff7e5f;
  font-weight: 500;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fafbfc;
  border-radius: 16rpx;
  border: 1rpx solid #f0f2f5;
}

.history-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.history-icon-box.pomodoro {
  background: linear-gradient(135deg, #FFE4E1 0%, #FFD1DC 100%);
}

.history-icon-box.shortBreak {
  background: linear-gradient(135deg, #D4F1F4 0%, #A8DADC 100%);
}

.history-icon-box.longBreak {
  background: linear-gradient(135deg, #F5F5DC 0%, #E8E4C9 100%);
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.history-name {
  font-size: 28rpx;
  color: #2c3e50;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.history-time {
  font-size: 24rpx;
  color: #95a5a6;
}

.history-date {
  font-size: 22rpx;
  color: #bdc3c7;
}

.history-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.history-duration {
  font-size: 26rpx;
  color: #FF69B4;
  font-weight: 600;
}

.history-points {
  font-size: 24rpx;
  color: #11998e;
  font-weight: 600;
  background: linear-gradient(135deg, #D4F5E0 0%, #A8E6CF 100%);
  padding: 4rpx 12rpx;
  border-radius: 100rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #95a5a6;
}

.bottom-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 32rpx 0 16rpx;
}

.bottom-tip-text {
  font-size: 24rpx;
  color: #b0b0b0;
}
