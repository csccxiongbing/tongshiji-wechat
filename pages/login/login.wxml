<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text>←</text>
    </view>
    <text class="page-title">登录</text>
  </view>
  
  <view class="form-card">
    <view class="form-item">
      <view class="input-wrapper">
        <text class="input-icon">📱</text>
        <input 
          class="input-field" 
          placeholder="请输入手机号" 
          value="{{phone}}"
          bindinput="onPhoneInput"
          type="number"
        />
      </view>
    </view>
    
    <view class="form-item">
      <view class="input-wrapper">
        <text class="input-icon">🔑</text>
        <input 
          class="input-field" 
          placeholder="请输入验证码" 
          value="{{code}}"
          bindinput="onCodeInput"
          type="number"
        />
        <view class="code-btn" bindtap="sendCode">
          <text>{{codeBtnText}}</text>
        </view>
      </view>
    </view>
    
    <view class="btn-primary login-btn" bindtap="login">
      <text>登录</text>
    </view>
    
    <view class="bottom-link">
      <text>还没有账号？</text>
      <text class="link" bindtap="goToRegister">立即注册</text>
    </view>
  </view>
  
</view>