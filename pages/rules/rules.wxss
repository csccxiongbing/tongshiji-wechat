.container {
  min-height: 100vh;
  background: #f8f9fa;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 60rpx 40rpx;
  text-align: center;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
}

.content {
  /* padding: 30rpx; */
  padding-bottom: 120rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.section-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

/* 规则卡片 */
.rule-card {
  background: white;
  border-radius: 20rpx;
  padding: 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.rule-item {
  display: flex;
  align-items: center;
  padding: 25rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.rule-item:last-child {
  border-bottom: none;
}

.rule-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.rule-info {
  flex: 1;
}

.rule-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.rule-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.rule-points {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  padding: 8rpx 20rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 30rpx;
}

.rule-cost {
  color: #ff6b6b;
  background: rgba(255, 107, 107, 0.1);
}

/* 等级系统 */
.level-display {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  color: white;
  margin-bottom: 20rpx;
}

.level-current {
  text-align: center;
  margin-bottom: 30rpx;
}

.level-label {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
}

.level-value {
  font-size: 80rpx;
  font-weight: bold;
  display: block;
  line-height: 1.2;
}

.level-name {
  font-size: 32rpx;
  display: block;
  opacity: 0.9;
}

.level-progress {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 20rpx;
}

.progress-bar {
  height: 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-fill {
  height: 100%;
  background: white;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  text-align: center;
  display: block;
}

.level-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.level-item {
  width: 30%;
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  margin-bottom: 20rpx;
  opacity: 0.4;
  transition: all 0.3s;
}

.level-item.unlocked {
  opacity: 1;
}

.level-item.current {
  opacity: 1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.level-badge {
  width: 60rpx;
  height: 60rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 10rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.level-item.current .level-badge {
  background: white;
  color: #667eea;
}

.level-item-name {
  font-size: 24rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 5rpx;
}

.level-item-points {
  font-size: 20rpx;
  color: #999;
  display: block;
}

.level-item.current .level-item-points {
  color: rgba(255, 255, 255, 0.8);
}

/* 勋章墙 */
.badges-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.badge-item {
  background: white;
  border-radius: 20rpx;
  padding: 25rpx 15rpx;
  text-align: center;
  position: relative;
  transition: all 0.3s;
}

.badge-item.locked {
  opacity: 0.5;
}

.badge-item.unlocked {
  background: linear-gradient(135deg, #fff7e6 0%, #fff3e0 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.2);
}

.badge-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.badge-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.badge-desc {
  font-size: 20rpx;
  color: #999;
  display: block;
  line-height: 1.4;
}

.badge-status {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: #52c41a;
  color: white;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.badge-lock {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  font-size: 24rpx;
}

/* 连续打卡 */
.streak-card {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  color: white;
  margin-bottom: 20rpx;
}

.streak-current {
  text-align: center;
  margin-bottom: 30rpx;
}

.streak-days {
  font-size: 100rpx;
  font-weight: bold;
  display: block;
  line-height: 1.1;
}

.streak-label {
  font-size: 28rpx;
  display: block;
  opacity: 0.9;
}

.streak-rewards {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 25rpx;
}

.rewards-title {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
}

.reward-item {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.reward-item:last-child {
  border-bottom: none;
}

.reward-days {
  font-size: 28rpx;
  flex: 1;
}

.reward-points {
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.reward-status {
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.reward-status.active {
  background: white;
  color: #fa709a;
}

.streak-tips {
  background: #fff9e6;
  border-radius: 16rpx;
  padding: 25rpx;
  border-left: 6rpx solid #faad14;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #faad14;
  display: block;
  margin-bottom: 10rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: block;
}
