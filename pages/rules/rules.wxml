<view class="container">
  <view class="header">
    <view class="header-icon">📜</view>
    <text class="header-title">积分规则</text>
    <text class="header-subtitle">了解如何获取积分、提升等级、获得勋章</text>
  </view>

  <scroll-view scroll-y class="content">
    
    <!-- 积分获取 -->
    <view class="section">
      <view class="section-header">
        <text class="section-icon">⭐</text>
        <text class="section-title">积分获取</text>
      </view>
      
      <view class="rule-card">
        <view class="rule-item" wx:for="{{pointsRules}}" wx:key="title">
          <view class="rule-icon">{{item.icon}}</view>
          <view class="rule-info">
            <text class="rule-title">{{item.title}}</text>
            <text class="rule-desc">{{item.desc}}</text>
          </view>
          <view class="rule-points">+{{item.points > 0 ? item.points +'分' : '积分'}}</view>
        </view>
      </view>
    </view>

    <!-- 等级系统 -->
    <view class="section">
      <view class="section-header">
        <text class="section-icon">🏆</text>
        <text class="section-title">等级系统</text>
      </view>
      
      <view class="level-display">
        <view class="level-current">
          <text class="level-label">当前等级</text>
          <text class="level-value">{{currentLevel}}</text>
          <text class="level-name">{{levelName}}</text>
        </view>
        <view class="level-progress">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{progressPercent}}%"></view>
          </view>
          <text class="progress-text">{{currentPoints}} / {{nextLevelPoints}} 积分</text>
        </view>
      </view>
      
      <view class="level-list">
        <view class="level-item {{item.reached ? 'reached' : ''}} {{item.current ? 'current' : ''}}" wx:for="{{levels}}" wx:key="level">
          <view class="level-badge">{{item.level}}</view>
          <text class="level-item-name">{{item.name}}</text>
          <text class="level-item-points">{{item.minPoints}}积分</text>
        </view>
      </view>
    </view>

    <!-- 勋章系统 -->
    <view class="section">
      <view class="section-header">
        <text class="section-icon">🎖️</text>
        <text class="section-title">勋章墙</text>
      </view>
      
      <view class="badges-grid">
        <view class="badge-item {{item.unlocked ? 'unlocked' : 'locked'}}" wx:for="{{badges}}" wx:key="id">
          <view class="badge-icon">{{item.icon}}</view>
          <text class="badge-name">{{item.name}}</text>
          <text class="badge-desc">{{item.condition}}</text>
          <view class="badge-status" wx:if="{{item.unlocked}}">已获得</view>
          <view class="badge-lock" wx:else>🔒</view>
        </view>
      </view>
    </view>

    <!-- 连续打卡规则 -->
    <view class="section">
      <view class="section-header">
        <text class="section-icon">🔥</text>
        <text class="section-title">连续打卡规则</text>
      </view>
      
      <view class="streak-card">
        <view class="streak-current">
          <text class="streak-days">{{streakDays}}</text>
          <text class="streak-label">连续打卡天数</text>
        </view>
        
        <view class="streak-rewards">
          <text class="rewards-title">连续奖励</text>
          <view class="reward-item" wx:for="{{streakRewards}}" wx:key="days">
            <text class="reward-days">{{item.days}}天</text>
            <text class="reward-points">+{{item.bonus}}分</text>
            <text class="reward-status {{streakDays >= item.days ? 'active' : ''}}">{{streakDays >= item.days ? '✓' : ''}}</text>
          </view>
        </view>
      </view>
      
      <view class="streak-tips">
        <text class="tips-title">💡 小贴士</text>
        <text class="tips-text">完成任意任务或番茄钟即可打卡，连续打卡可获得额外积分奖励哦！</text>
      </view>
    </view>

    <!-- 积分消耗 -->
    <view class="section">
      <view class="section-header">
        <text class="section-icon">🎁</text>
        <text class="section-title">积分消耗</text>
      </view>
      
      <view class="rule-card">
        <view class="rule-item">
          <view class="rule-icon">🎁</view>
          <view class="rule-info">
            <text class="rule-title">兑换心愿</text>
            <text class="rule-desc">使用积分兑换心愿奖励</text>
          </view>
          <view class="rule-points rule-cost">-积分</view>
        </view>
        
        <view class="rule-item">
          <view class="rule-icon">↩️</view>
          <view class="rule-info">
            <text class="rule-title">取消任务</text>
            <text class="rule-desc">取消已完成的任务会扣除积分</text>
          </view>
          <view class="rule-points rule-cost">-积分</view>
        </view>
      </view>
    </view>

  </scroll-view>
</view>
