page {
  background: #f5f7fa;
  min-height: 100vh;
}

.container {
  padding: 0;
  min-height: 100vh;
  background: #f5f7fa;
}

.points-card {
  position: relative;
  margin: 30rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #ff7e5f 0%, #feb47b 100%);
  padding: 40rpx;
  box-shadow: 0 20rpx 40rpx rgba(255, 126, 95, 0.3);
  margin-top: 40rpx;
}

.points-bg {
  position: absolute;
  top: -60%;
  right: -30%;
  width: 280rpx;
  height: 280rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
}

.points-bg-small {
  position: absolute;
  bottom: -20%;
  left: -10%;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.points-content {
  position: relative;
  z-index: 1;
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 28rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  transition: all 0.3s ease;
}

.history-btn:active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.3);
}

.history-icon {
  font-size: 28rpx;
}

.points-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.points-value {
  display: flex;
  align-items: baseline;
  margin-bottom: 30rpx;
}

.points-star {
  font-size: 50rpx;
  margin-right: 12rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.points-num {
  font-size: 96rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.points-buttons {
  display: flex;
  gap: 20rpx;
}

.points-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.points-btn:active {
  transform: scale(0.96);
}

.points-btn.add {
  background: #fff;
  color: #ff7e5f;
  box-shadow: 0 8rpx 20rpx rgba(255, 126, 95, 0.3);
}

.points-btn.subtract {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  backdrop-filter: blur(10px);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.btn-icon {
  margin-right: 10rpx;
  font-size: 36rpx;
}

.member-tabs {
  display: flex;
  padding: 0 30rpx;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.member-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 3rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.member-tab.active {
  border-color: #ff7e5f;
  background: #fff8f6;
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(255, 126, 95, 0.2);
}

.tab-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.tab-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.tab-points {
  font-size: 24rpx;
  color: #ff7e5f;
  margin-left: 6rpx;
  font-weight: 600;
}

.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 30rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  margin-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f2f5;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2c3e50;
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  background: #fff;
  border-radius: 40rpx;
  border: 2rpx solid #667eea;
  color: #667eea;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
  transition: all 0.3s ease;
}

.add-btn:active {
  transform: scale(0.95);
  background: #f8f9ff;
}

.add-icon {
  font-size: 28rpx;
  font-weight: 400;
}

.add-text {
  font-size: 24rpx;
}

.wishes-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.wish-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 2rpx solid #f0f2f5;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.wish-item:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  border-color: #ff7e5f;
}

.wish-icon {
  font-size: 84rpx;
  margin-bottom: 16rpx;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #fff0e8 0%, #fffaf5 100%);
  border-radius: 50%;
  border: 2rpx solid #ffe5d9;
}

.wish-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.wish-name {
  font-size: 28rpx;
  color: #2c3e50;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.wish-meta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 16rpx;
}

.wish-points {
  font-size: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff7e5f 0%, #feb47b 100%);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 700;
}

.wish-limit,
.wish-assigned {
  font-size: 22rpx;
  color: #95a5a6;
  padding: 4rpx 12rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
}

.wish-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  width: 100%;
}

.exchange-btn,
.delete-btn {
  padding: 12rpx 0;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.3s ease;
  width: 100%;
}

.exchange-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.35);
}

.exchange-btn:active {
  transform: scale(0.96);
}

.exchange-btn.disabled {
  background: #e9ecef;
  color: #adb5bd;
  box-shadow: none;
}

.delete-btn {
  background: #f8f9fa;
  color: #6c757d;
  border: none;
}

.delete-btn:active {
  background: #ffe5e5;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fafbfc;
  border-radius: 16rpx;
  border: 1rpx solid #f0f2f5;
}

.history-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.history-wish {
  font-size: 30rpx;
  color: #2c3e50;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.history-member {
  font-size: 24rpx;
  color: #95a5a6;
}

.history-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.history-points {
  font-size: 30rpx;
  color: #e74c3c;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.history-time {
  font-size: 22rpx;
  color: #bdc3c7;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #95a5a6;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 999;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow-y: auto;
  overflow-x: hidden;
  animation: slideUp 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f2f5;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 1;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2c3e50;
}

.modal-close {
  font-size: 48rpx;
  color: #95a5a6;
  line-height: 1;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 30rpx;
  color: #2c3e50;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-input {
  width: 100%;
  padding: 28rpx 24rpx;
  border: 2rpx solid #e8eaed;
  border-radius: 16rpx;
  font-size: 32rpx;
  line-height: 1.6;
  box-sizing: border-box;
  background: #fff;
  color: #2c3e50;
  transition: all 0.3s ease;
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

.form-input:focus {
  border-color: #ff7e5f;
  background: #fff;
  box-shadow: 0 0 0 6rpx rgba(255, 126, 95, 0.15);
}

.form-input::placeholder {
  color: #bdc3c7;
  font-size: 30rpx;
}

.icon-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 8rpx 0;
}

.icon-option {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 3rpx solid #e8eaed;
  transition: all 0.2s ease;
  cursor: pointer;
}

.icon-option:active {
  transform: scale(0.94);
  background: #fff5f0;
}

.icon-option.active {
  background: linear-gradient(135deg, #fff0e8 0%, #fff5f0 100%);
  border-color: #ff7e5f;
  box-shadow: 0 4rpx 16rpx rgba(255, 126, 95, 0.3);
}

.member-checklist {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 4rpx 0;
}

.check-item {
  display: flex;
  align-items: center;
  padding: 12rpx 48rpx;
  background: #f8f9fa;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #6c757d;
  border: 2rpx solid #e9ecef;
  transition: all 0.2s ease;
  min-height: 56rpx;
}

.check-item:active {
  transform: scale(0.96);
}

.check-item.active {
  background: linear-gradient(135deg, #ff7e5f 0%, #feb47b 100%);
  color: #fff !important;
  border-color: #ff7e5f;
  box-shadow: 0 6rpx 20rpx rgba(255, 126, 95, 0.4);
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f2f5;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  position: sticky;
  bottom: 0;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.modal-btn:active {
  transform: scale(0.98);
}

.modal-btn.cancel {
  background: #f8f9fa;
  color: #6c757d;
  margin-right: 20rpx;
  border: 2rpx solid #e9ecef;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #ff7e5f 0%, #feb47b 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 126, 95, 0.35);
}

.modal-btn.confirm.points {
  background: linear-gradient(135deg, #ff7e5f 0%, #feb47b 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 126, 95, 0.35);
}

.modal-btn.delete {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: #fff;
  margin-right: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(231, 76, 60, 0.35);
}

.picker-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  /* padding: 28rpx 24rpx; */
  border: 2rpx solid #e8eaed;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #2c3e50;
  background: #fff;
  min-height: 88rpx;
}

.picker-arrow {
  font-size: 24rpx;
  color: #bdc3c7;
}

.picker-content:active {
  background: #f8f9fa;
  border-color: #ff7e5f;
}

.switch {
  transform: scale(0.9);
}

::-webkit-scrollbar {
  width: 0;
  height: 0;
  background: transparent;
}
