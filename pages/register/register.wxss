.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFE4E1 100%);
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

.header {
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #FF69B4;
  margin-right: 20rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.form-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(255, 105, 180, 0.15);
}

.form-item {
  margin-bottom: 30rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #FFF5F5;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #FFE4E1;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.code-btn {
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  color: #FFFFFF;
  border-radius: 30rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
}

.register-btn {
  margin-top: 40rpx;
  padding: 28rpx;
  font-size: 32rpx;
}

.bottom-link {
  text-align: center;
  margin-top: 40rpx;
  font-size: 26rpx;
  color: #999999;
}

.link {
  color: #FF69B4;
  margin-left: 8rpx;
}

