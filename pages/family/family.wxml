<view class="container">
  <view class="header">
    <text class="page-title">家庭管理</text>
    <text class="page-subtitle">选择创建或加入家庭</text>
  </view>
  
  <view class="family-section">
    <view class="family-card create-card" hover-class="card-hover" hover-stay-time="100" bindtap="goToCreateFamily">
      <view class="family-icon" hover-class="icon-hover">
        <text>🏠</text>
      </view>
      <view class="family-info">
        <text class="family-title">创建新家庭</text>
        <text class="family-desc">成为家庭管理员，邀请家人加入</text>
      </view>
      <text class="arrow">→</text>
    </view>
    
    <view class="family-card join-card" hover-class="card-hover" hover-stay-time="100" bindtap="goToJoinFamily">
      <view class="family-icon" hover-class="icon-hover">
        <text>👨‍👩‍👧</text>
      </view>
      <view class="family-info">
        <text class="family-title">加入已有家庭</text>
        <text class="family-desc">输入邀请码加入家人的家庭</text>
      </view>
      <text class="arrow">→</text>
    </view>
  </view>
  
  <view class="tips">
    <text class="tips-icon">💡</text>
    <text class="tips-text">每个家庭可以创建多个孩子的日程</text>
  </view>
  
</view>