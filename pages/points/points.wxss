.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFE4E1 100%);
  padding: 0 0 120rpx;
}

.header-section {
  padding: 60rpx 32rpx;
}

.points-card {
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 105, 180, 0.3);
}

.points-icon {
  font-size: 80rpx;
  margin-right: 24rpx;
}

.points-info {
  flex: 1;
}

.points-value {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.points-level {
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  color: #fff;
  font-size: 24rpx;
}

.section {
  padding: 0 32rpx 32rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.tasks-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.task-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.task-info {
  flex: 1;
}

.task-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.task-desc {
  font-size: 24rpx;
  color: #999;
}

.task-points {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF69B4;
}

.history-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.history-item {
  padding: 24rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-icon {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF69B4;
  margin-right: 20rpx;
}

.history-info {
  flex: 1;
}

.history-reason {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.history-time {
  font-size: 22rpx;
  color: #999;
}

.history-balance {
  font-size: 24rpx;
  color: #666;
}

.rewards-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.reward-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.reward-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.reward-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.reward-cost {
  font-size: 24rpx;
  color: #FF69B4;
  display: block;
  margin-bottom: 16rpx;
}

.reward-btn {
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  color: #fff;
  padding: 16rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
}

.reward-btn.disabled {
  background: #ccc;
}

.empty-state {
  padding: 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

