<view class="container">
  <view class="filter-section">
    <view class="filter-row">
      <view class="filter-item">
        <text class="filter-icon">📅</text>
        <picker mode="selector" range="{{timeOptions}}" range-key="label" value="{{selectedTimeIndex}}" bindchange="onTimeChange">
          <view class="picker-box">
            <text class="picker-text">{{timeOptions[selectedTimeIndex].label}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      
      <view class="filter-item">
        <text class="filter-icon">📊</text>
        <picker mode="selector" range="{{typeOptions}}" range-key="label" value="{{selectedTypeIndex}}" bindchange="onTypeChange">
          <view class="picker-box">
            <text class="picker-text">{{typeOptions[selectedTypeIndex].label}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      
      <view class="filter-item">
        <text class="filter-icon">👶</text>
        <picker mode="selector" range="{{memberOptions}}" range-key="label" value="{{selectedMemberIndex}}" bindchange="onMemberChange">
          <view class="picker-box">
            <text class="picker-text">{{memberOptions[selectedMemberIndex].label}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>
  </view>
  
  <view class="section" wx:if="{{selectedType === 'all' || selectedType === 'points'}}">
    <view class="section-header">
      <text class="section-title">积分记录</text>
      <text class="section-count">共{{filteredPointsHistory.length}}条</text>
    </view>
    
    <view class="history-list">
      <block wx:for="{{displayedPointsHistory}}" wx:key="id">
        <view class="history-item">
          <view class="history-icon-points {{item.amount > 0 ? 'add' : 'subtract'}}">
            <text>{{item.amount > 0 ? '+' : ''}}{{item.amount}}</text>
          </view>
          <view class="history-info">
            <text class="history-reason">{{item.reason}}</text>
            <text class="history-member">{{item.memberName}}</text>
            <text class="history-time">{{item.time}}</text>
          </view>
          <view class="history-balance">余额: {{item.balance}}</view>
        </view>
      </block>
      
      <view wx:if="{{displayedPointsHistory.length === 0}}" class="empty-state">
        <text class="empty-icon">📝</text>
        <text class="empty-text">暂无积分记录</text>
      </view>
      
      <view class="load-more" wx:if="{{displayedPointsHistory.length < filteredPointsHistory.length}}" bindtap="loadMorePoints">
        <text class="load-more-text">加载更多</text>
      </view>
    </view>
  </view>
  
  <view class="section" wx:if="{{selectedType === 'all' || selectedType === 'wish'}}">
    <view class="section-header">
      <text class="section-title">心愿兑换记录</text>
      <text class="section-count">共{{filteredWishHistory.length}}条</text>
    </view>
    
    <view class="history-list">
      <block wx:for="{{displayedWishHistory}}" wx:key="_id">
        <view class="history-item">
          <view class="history-icon-wish">🎁</view>
          <view class="history-info">
            <text class="history-reason">兑换"{{item.wishName}}"</text>
            <text class="history-member">{{item.memberName}}</text>
            <text class="history-time">{{formatDate(item.exchangeTime)}}</text>
          </view>
          <view class="history-balance-wish">-{{item.points}}</view>
        </view>
      </block>
      
      <view wx:if="{{displayedWishHistory.length === 0}}" class="empty-state">
        <text class="empty-icon">🎁</text>
        <text class="empty-text">暂无兑换记录</text>
      </view>
      
      <view class="load-more" wx:if="{{displayedWishHistory.length < filteredWishHistory.length}}" bindtap="loadMoreWishes">
        <text class="load-more-text">加载更多</text>
      </view>
    </view>
  </view>
</view>
