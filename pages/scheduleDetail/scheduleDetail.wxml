<view class="container">
  <view class="header-bar">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">日程详情</text>
    <view class="header-placeholder"></view>
  </view>

  <view class="detail-card" wx:if="{{schedule}}">
    <view class="detail-icon-wrapper">
      <view class="detail-icon" style="background: {{schedule.color}}">
        <text>{{schedule.icon}}</text>
      </view>
    </view>

    <view class="detail-content">
      <view class="detail-row">
        <text class="detail-label">日程标题</text>
        <text class="detail-title">{{schedule.title}}</text>
      </view>

      <view class="detail-row time-row" wx:if="{{schedule.startTime}}">
        <text class="detail-label">开始时间</text>
        <view class="time-display">
          <text class="time-date">{{schedule.startDate}}</text>
          <text class="time-clock">{{schedule.startTimeOnly}}</text>
        </view>
      </view>

      <view class="detail-row time-row" wx:if="{{schedule.endTime}}">
        <text class="detail-label">结束时间</text>
        <view class="time-display">
          <text class="time-date">{{schedule.endDate}}</text>
          <text class="time-clock">{{schedule.endTimeOnly}}</text>
        </view>
      </view>

      <view class="detail-row" wx:if="{{memberStatusList.length > 0}}">
        <text class="detail-label">参与成员</text>
        <view class="detail-members">
          <view wx:for="{{memberStatusList}}" wx:key="index" class="member-item">
            <text class="member-tag {{item.completed ? 'completed' : ''}}">
              {{item.name}}
              <text wx:if="{{item.completed}}" class="check-icon"> ✓</text>
            </text>
          </view>
        </view>
      </view>

      <view class="detail-row" wx:if="{{schedule.repeatRule && schedule.repeatRuleText}}">
        <text class="detail-label">重复规则</text>
        <text class="detail-value">🔄 {{schedule.repeatRuleText}}</text>
      </view>

      <view class="detail-row" wx:if="{{schedule.remindEnabled}}">
        <text class="detail-label">提醒设置</text>
        <view class="remind-section">
          <text class="remind-status">{{schedule.remindEnabled ? '已开启' : '未开启'}}</text>
          <view class="detail-members remind-members" wx:if="{{schedule.remindMembers && schedule.remindMembers.length > 0}}">
            <text wx:for="{{schedule.remindMembers}}" wx:key="index" class="member-tag remind-tag">
              {{item}}
            </text>
          </view>
        </view>
      </view>

      <view class="detail-row" wx:if="{{schedule.points && schedule.points > 0}}">
        <text class="detail-label">积分奖励</text>
        <view class="detail-points">
          <text class="points-icon">⭐</text>
          <text class="points-value">+{{schedule.points}} 积分</text>
        </view>
      </view>

      <view class="detail-row" wx:if="{{schedule.note}}">
        <text class="detail-label">备注</text>
        <text class="detail-value note-text">{{schedule.note}}</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!schedule}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">未找到日程详情</text>
  </view>
</view>
