.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFE4E1 100%);
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
  margin-top: 60rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999999;
  margin-top: 16rpx;
  display: block;
}

.role-section {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 80rpx;
}

.role-card {
  width: 280rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx 30rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(255, 105, 180, 0.15);
  position: relative;
  transition: all 0.3s ease;
  border: 3rpx solid transparent;
}

.role-card.selected {
  border-color: #FF69B4;
  background: #FFF0F5;
  transform: scale(1.05);
}

.role-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  font-size: 64rpx;
}

.parent-icon {
  background: linear-gradient(135deg, #4ECDC4 0%, #44A08D 100%);
}

.child-icon {
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
}

.role-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.role-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
  display: block;
}

.check-mark {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.confirm-btn {
  padding: 28rpx;
  font-size: 32rpx;
}

