<view class="container">
  <view class="header-section">
    <view class="date-member-row">
      <view class="month-info">
        <text class="month-title">{{currentMonth}}月</text>
        <text class="year-text">{{currentYear}}年</text>
      </view>
      <view class="member-selector" bindtap="toggleMemberPicker">
        <text class="member-text">家庭成员</text>
        <text class="arrow">{{showMemberPicker ? '▲' : '▼'}}</text>
      </view>
    </view>
  </view>
  
  <view class="member-picker-overlay" wx:if="{{showMemberPicker}}" bindtap="toggleMemberPicker"></view>
  <view class="member-picker" wx:if="{{showMemberPicker}}">
    <view class="picker-arrow"></view>
    <view 
      class="picker-item picker-item-first {{selectedMembers.length === familyMembers.length ? 'active' : ''}}" 
      bindtap="toggleSelectAll"
    >
      <view class="member-checkbox-wrapper">
        <view class="member-checkbox {{selectedMembers.length === familyMembers.length ? 'member-checked' : ''}}">
          <text wx:if="{{selectedMembers.length === familyMembers.length}}">✓</text>
        </view>
      </view>
      <text>我的家庭</text>
    </view>
    <view class="divider"></view>
    <block wx:for="{{familyMembers}}" wx:key="name">
      <view 
        class="picker-item picker-item-child {{item.isSelected ? 'active' : ''}}" 
        bindtap="toggleMember"
        data-member="{{item.name}}"
        data-index="{{index}}"
      >
        <view class="member-checkbox-wrapper">
          <view class="member-checkbox {{item.isSelected ? 'member-checked' : ''}}">
            <text wx:if="{{item.isSelected}}">✓</text>
          </view>
        </view>
        <text>{{item.name}}</text>
      </view>
    </block>
  </view>
  
  <scroll-view scroll-y class="scroll-content">
  
  <view class="week-nav">
    <block wx:for="{{weekDays}}" wx:key="index">
      <view 
        class="week-item {{selectedDay === index ? 'active' : ''}}" 
        bindtap="selectDay"
        data-day="{{index}}"
      >
        <text class="week-name">{{item.name}}</text>
        <text class="week-date">{{item.date}}</text>
        <view wx:if="{{item.hasSchedule}}" class="week-dot"></view>
      </view>
    </block>
  </view>
  
  <view class="section">
    <view class="section-header">
      <text class="section-title">{{selectedDayName}}日程</text>
      <view class="add-btn" bindtap="goToAddSchedule">
        <text>+ 添加</text>
      </view>
    </view>
    
    <view class="schedule-list">
      <block wx:for="{{daySchedules}}" wx:key="id">
        <view class="schedule-item {{item.completed ? 'completed' : ''}}" bindtap="viewScheduleDetail" data-id="{{item.id}}">
          <view class="schedule-main">
            <view class="schedule-top">
              <view class="top-left">
                <view class="top-row">
                  <view class="time-capsule" wx:if="{{item.startTime && item.endTime}}">
                    <text class="time-icon">🕐</text>
                    <text class="time-text">{{item.formattedStartTime}} - {{item.formattedEndTime}}</text>
                  </view>
                  <view class="time-capsule" wx:elif="{{item.time}}">
                    <text class="time-icon">🕐</text>
                    <text class="time-text">{{item.time}}</text>
                  </view>
                  
                  <text class="badge-item badge-repeat" wx:if="{{item.repeatRule && item.repeatRule !== 'never'}}">🔄 {{item.repeatRuleText}}</text>
                  <text class="badge-item badge-points" wx:if="{{item.points && item.points > 0}}">⭐ {{item.points}}</text>
                </view>
              </view>
              
              <view class="top-right" wx:if="{{item.remindEnabled && item.remindMembers && item.remindMembers.length > 0}}">
                <text class="remind-badge">🔔</text>
                <text class="remind-name" wx:for="{{item.remindMembers}}" wx:for-item="remindMember" wx:key="*this">{{remindMember}}</text>
              </view>
            </view>
            
            <view class="schedule-divider"></view>
            
            <view class="schedule-content">
              <view class="schedule-icon" style="background: {{item.color}}">
                <text>{{item.icon}}</text>
              </view>
              
              <view class="content-text">
                <view class="schedule-title-row">
                  <text class="schedule-title">{{item.title}}</text>
                </view>
                
                <view class="schedule-note" wx:if="{{item.note}}">
                  <text class="note-icon">📝</text>
                  <text class="note-text">{{item.note}}</text>
                </view>
              </view>
              
              <!-- 家长角色：显示成员完成按钮 -->
              <view class="member-buttons" wx:if="{{!isChildRole}}">
                <view
                  wx:for="{{item.memberStatus}}"
                  wx:for-item="ms"
                  wx:key="name"
                  class="member-button {{ms.completed ? 'completed' : ''}} {{ms.showFireworks ? 'fireworks' : ''}}"
                  catchtap="toggleMemberComplete"
                  data-id="{{item.id}}"
                  data-member="{{ms.name}}"
                >
                  <view wx:if="{{showPointsPopup && pointsScheduleId === item.id && pointsPopupMember === ms.name}}" class="points-popup">
                    <text class="points-popup-text">{{pointsPopupText}}</text>
                  </view>
                  <text class="member-name">{{ms.name}}</text>
                  <text wx:if="{{ms.completed}}" class="check-icon">✓</text>
                  <view wx:if="{{ms.showFireworks}}" class="fireworks-container">
                    <view class="firework firework-1"></view>
                    <view class="firework firework-2"></view>
                    <view class="firework firework-3"></view>
                    <view class="firework firework-4"></view>
                    <view class="firework firework-5"></view>
                    <view class="firework firework-6"></view>
                    <view class="firework firework-7"></view>
                    <view class="firework firework-8"></view>
                  </view>
                </view>
              </view>
              
              <!-- 孩子角色：显示开始/已完成按钮 + 禁用其他成员按钮 -->
              <view class="member-buttons child-mode" wx:if="{{isChildRole}}">
                <block wx:for="{{item.memberStatus}}" wx:for-item="ms" wx:key="name">
                  <!-- 自己的按钮：显示开始/已完成 -->
                  <view
                    wx:if="{{ms.isMe && !ms.completed}}"
                    class="start-button"
                    catchtap="startPomodoro"
                    data-id="{{item.id}}"
                    data-member="{{ms.name}}"
                    data-points="{{item.points}}"
                  >
                    <view wx:if="{{showPointsPopup && pointsScheduleId === item.id}}" class="points-popup">
                      <text class="points-popup-text">{{pointsPopupText}}</text>
                    </view>
                    <text class="start-icon">▶</text>
                    <text class="start-text">开始</text>
                    <view class="points-tag" wx:if="{{item.points && item.points > 0}}">
                      <text class="points-star">⭐</text>
                      <text class="points-num">+{{item.points}}</text>
                    </view>
                  </view>
                  
                  <!-- 自己已完成：显示已完成 -->
                  <view
                    wx:if="{{ms.isMe && ms.completed}}"
                    class="start-button started {{ms.showFireworks ? 'fireworks' : ''}}"
                    catchtap="startPomodoro"
                    data-id="{{item.id}}"
                    data-member="{{ms.name}}"
                    data-points="{{item.points}}"
                  >
                    <text class="start-icon">✓</text>
                    <text class="start-text">已完成</text>
                    <view wx:if="{{ms.showFireworks}}" class="fireworks-container">
                      <view class="firework firework-1"></view>
                      <view class="firework firework-2"></view>
                      <view class="firework firework-3"></view>
                      <view class="firework firework-4"></view>
                      <view class="firework firework-5"></view>
                      <view class="firework firework-6"></view>
                      <view class="firework firework-7"></view>
                      <view class="firework firework-8"></view>
                    </view>
                  </view>
                  
                  <!-- 其他成员：禁用按钮 -->
                  <view
                    wx:if="{{!ms.isMe}}"
                    class="member-button member-disabled {{ms.completed ? 'completed' : ''}}"
                  >
                    <text class="member-name">{{ms.name}}</text>
                    <text wx:if="{{ms.completed}}" class="check-icon">✓</text>
                  </view>
                </block>
              </view>
            </view>
          </view>
        </view>
      </block>
      
      <view wx:if="{{daySchedules.length === 0}}" class="empty-state">
        <text class="empty-icon">📅</text>
        <text class="empty-text">这天还没有日程安排</text>
      </view>
    </view>
  </view>
  
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value">{{totalSchedules}}</text>
      <text class="stat-label">总日程</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{completedSchedules}}</text>
      <text class="stat-label">已完成</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{avgCompletion}}%</text>
      <text class="stat-label">完成率</text>
    </view>
  </view>
  
  </scroll-view>
  
  <custom-tab-bar />
</view>
