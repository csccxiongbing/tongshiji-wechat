<view class="container">
  <view class="members-section">
    <text class="section-title">家庭成员</text>
    <view class="members-list">
      <block wx:for="{{familyMembers}}" wx:key="index">
        <view class="member-card {{item.isCurrentUser ? 'current-user' : ''}}">
          <view class="member-info">
            <view class="member-avatar">
              <text>{{item.role === 'parent' ? '👨' : '👧'}}</text>
            </view>
            <view class="member-details">
              <view class="member-top-row">
                <text class="member-name">{{item.name}} <text wx:if="{{item.isCurrentUser}}" class="current-label">我</text></text>
                <text class="member-role">{{item.role === 'parent' ? '家长' : '孩子'}}</text>
              </view>
              <text wx:if="{{item.phone}}" class="member-phone">{{item.phone}}</text>
            </view>
          </view>
          <view class="member-actions">
            <view 
              wx:if="{{currentUserRole === 'parent' || (currentUserRole === 'child' && item.isCurrentUser)}}" 
              class="edit-btn" 
              bindtap="editMember"
              data-index="{{index}}"
            >
              <text class="edit-icon">✏️</text>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="family-section">
    <view class="family-card add-card" hover-class="card-hover" hover-stay-time="100" bindtap="goToAddMember">
      <view class="family-icon" hover-class="icon-hover">
        <text>👨‍👩‍👧</text>
      </view>
      <view class="family-info">
        <text class="family-title">新增家庭成员</text>
        <text class="family-desc">添加新的家庭成员到您的家庭</text>
      </view>
      <text class="arrow">→</text>
    </view>
    
    <view class="family-card join-card" hover-class="card-hover" hover-stay-time="100" bindtap="goToJoinFamily">
      <view class="family-icon" hover-class="icon-hover">
        <text>🔗</text>
      </view>
      <view class="family-info">
        <text class="family-title">加入已有家庭</text>
        <text class="family-desc">输入邀请码加入家人的家庭</text>
      </view>
      <text class="arrow">→</text>
    </view>
  </view>

  <view class="family-code-section">
    <view class="code-card">
      <text class="section-title">家庭码</text>
      <view class="code-display">
        <view class="code-boxes">
          <view class="code-box" wx:for="{{familyCode}}" wx:key="index">
            <text class="code-char">{{item}}</text>
          </view>
        </view>
      </view>
      <view class="copy-btn" bindtap="copyFamilyCode">
        <text class="copy-text">复制家庭码</text>
      </view>
      
      <view class="divider-line"></view>
      
      <view class="guide-section">
        <view class="guide-list">
          <view class="guide-item">
            <view class="guide-number">1</view>
            <view class="guide-content">
              <text class="guide-step">复制家庭码 → 发送给家人</text>
            </view>
          </view>
          <view class="guide-item">
            <view class="guide-number">2</view>
            <view class="guide-content">
              <text class="guide-step">打开小程序 → 注册登录 → 加入家庭 → 输入家庭码 → 加入家庭成功</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <view class="tips">
    <text class="tips-icon">💡</text>
    <text class="tips-text">每个家庭最多可添加10位成员</text>
  </view>
  
  <!-- 编辑成员弹窗 -->
  <view class="modal-overlay" wx:if="{{showEditModal}}" bindtap="closeEditModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">编辑成员</text>
        <text class="modal-close" bindtap="closeEditModal">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">角色名称</text>
          <input 
            class="form-input" 
            placeholder="请输入角色名称" 
            value="{{editForm.name}}"
            bindinput="onEditNameInput"
          />
        </view>
        <view class="form-item">
          <text class="form-label">手机号</text>
          <input 
            class="form-input" 
            type="number"
            placeholder="请输入手机号" 
            value="{{editForm.phone}}"
            bindinput="onEditPhoneInput"
            maxlength="11"
          />
        </view>
      </view>
      <view class="modal-footer">
        <view class="cancel-btn" bindtap="closeEditModal">
          <text>取消</text>
        </view>
        <view class="confirm-btn" bindtap="saveMember">
          <text>保存</text>
        </view>
      </view>
    </view>
  </view>
</view>