.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFE4E1 100%);
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  margin-top: 60rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.page-subtitle {
  font-size: 28rpx;
  color: #999999;
  margin-top: 16rpx;
  display: block;
}

.family-section {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.family-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(255, 105, 180, 0.15);
  transition: all 0.3s ease;
  transform: translateY(0);
}

.card-hover {
  transform: translateY(-4rpx) scale(1.02);
  box-shadow: 0 12rpx 40rpx rgba(255, 105, 180, 0.25);
}

.card-hover .arrow {
  transform: translateX(8rpx);
}

.add-card {
  border-left: 8rpx solid #4ECDC4;
}

.add-card.card-hover {
  box-shadow: 0 12rpx 40rpx rgba(78, 205, 196, 0.25);
}

.add-card .icon-hover {
  background: rgba(78, 205, 196, 0.2);
  box-shadow: 0 0 20rpx rgba(78, 205, 196, 0.4);
}

.join-card {
  border-left: 8rpx solid #FF69B4;
}

.join-card.card-hover {
  box-shadow: 0 12rpx 40rpx rgba(255, 105, 180, 0.25);
}

.join-card .icon-hover {
  background: rgba(255, 105, 180, 0.2);
  box-shadow: 0 0 20rpx rgba(255, 105, 180, 0.4);
}

.family-icon {
  width: 100rpx;
  height: 100rpx;
  background: #FFF5F5;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
  transition: all 0.3s ease;
  position: relative;
}

.icon-hover {
  transform: scale(1.1);
  animation: pulse 0.5s ease-in-out;
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.15);
  }
  100% {
    transform: scale(1.1);
  }
}

.family-info {
  flex: 1;
}

.family-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.family-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  display: block;
}

.arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  transition: transform 0.3s ease;
}

.family-code-section {
  margin-top: 40rpx;
}

.code-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 105, 180, 0.15);
}

.divider-line {
  height: 1rpx;
  background: #F0F0F0;
  margin: 30rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

.code-display {
  text-align: center;
  margin-bottom: 24rpx;
}

.code-boxes {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.code-box {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFE4E1 0%, #FFF0F5 100%);
  border: 3rpx solid #FFB6C1;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.15);
}

.code-char {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF69B4;
  font-family: 'Courier New', monospace;
}

.copy-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  border-radius: 30rpx;
  padding: 20rpx;
  transition: all 0.3s ease;
}

.copy-btn:active {
  transform: scale(0.98);
}

.copy-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.copy-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.guide-section {
  padding: 0;
}

.guide-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 24rpx;
}

.guide-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.guide-item {
  display: flex;
  align-items: flex-start;
}

.guide-number {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.guide-content {
  flex: 1;
}

.guide-step {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.tips {
  margin-top: 40rpx;
  background: #FFF0F5;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #FF69B4;
}

.members-section {
  margin-bottom: 40rpx;
}

.members-section .section-title {
  text-align: left;
  margin-bottom: 20rpx;
}

.members-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.member-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(255, 105, 180, 0.1);
}

.member-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFE4E1 0%, #FFF0F5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.member-details {
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.member-role {
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
  display: block;
}

.member-card.current-user {
  border: 3rpx solid #FF69B4;
  box-shadow: 0 4rpx 20rpx rgba(255, 105, 180, 0.2);
}

.current-label {
  font-size: 20rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  font-weight: 500;
}

.member-actions {
  display: flex;
  align-items: center;
}

.edit-btn {
  width: 56rpx;
  height: 56rpx;
  background: #FFF0F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.edit-btn:active {
  background: #FFE4E1;
  transform: scale(0.95);
}

.edit-icon {
  font-size: 28rpx;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(40rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 48rpx;
  color: #CCCCCC;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.cancel-btn {
  background: #F0F0F0;
  color: #666666;
}

.confirm-btn {
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  color: #FFFFFF;
}

.cancel-btn:active,
.confirm-btn:active {
  transform: scale(0.98);
}