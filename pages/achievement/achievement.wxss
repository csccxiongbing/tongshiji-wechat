.container {
  min-height: 100vh;
  background: #FFF9F0;
  padding-bottom: 120rpx;
}

.achieve-header {
  background: linear-gradient(135deg, #B388FF 0%, #7C4DFF 50%, #FF80AB 100%);
  padding: 56rpx 40rpx;
  color: #fff;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.achieve-header::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}

.achieve-title {
  font-size: 44rpx;
  font-weight: 900;
  flex: 1;
  text-align: center;
}

.header-top {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
}

.child-picker {
  position: absolute;
  right: 0;
}

.picker-trigger {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 24rpx;
  transition: all 0.2s ease;
}

.picker-trigger:active {
  background: rgba(255, 255, 255, 0.35);
}

.picker-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.picker-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  transition: transform 0.2s ease;
}

.picker-arrow.arrow-up {
  transform: rotate(90deg);
}

.picker-dropdown {
  position: absolute;
  top: calc(100% + 8rpx);
  right: 0;
  min-width: 180rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.picker-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: #333;
  transition: background 0.15s ease;
}

.picker-option:active {
  background: #f5f5f5;
}

.picker-option.selected {
  color: #7C4DFF;
  background: #f8f4ff;
}

.option-check {
  font-size: 24rpx;
  color: #7C4DFF;
}

.level-badge {
  display: inline-flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 48rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.crown-icon {
  font-size: 48rpx;
}

.level-progress {
  margin-top: 40rpx;
  max-width: 520rpx;
  margin-left: auto;
  margin-right: auto;
}

.level-bar {
  height: 20rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 10rpx;
  overflow: hidden;
}

.level-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFE66D 0%, #FFD54F 100%);
  border-radius: 10rpx;
  transition: width 0.8s ease;
}

.level-text {
  font-size: 26rpx;
  margin-top: 16rpx;
  opacity: 0.85;
  display: block;
}

.stats-card {
  background: #fff;
  margin: 32rpx;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
}

.stats-item {
  text-align: center;
  flex: 1;
}

.stats-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.stats-val {
  font-size: 48rpx;
  font-weight: 900;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.stats-lbl {
  font-size: 24rpx;
  color: #999;
}

.stats-divider {
  width: 2rpx;
  height: 80rpx;
  background: #F0F0F0;
}

.streak-card {
  background: linear-gradient(135deg, #FFA726 0%, #FF7043 100%);
  margin: 32rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  color: #fff;
  display: flex;
  align-items: center;
  gap: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(255,167,38,0.3);
}

.streak-icon {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.streak-info {
  flex: 1;
}

.streak-val {
  font-size: 64rpx;
  font-weight: 900;
  display: block;
}

.streak-lbl {
  font-size: 28rpx;
  opacity: 0.9;
}

.streak-best {
  text-align: right;
}

.streak-best-val {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
}

.streak-best-lbl {
  font-size: 24rpx;
  opacity: 0.8;
}

.badge-section {
  padding: 40rpx 32rpx;
}

.badge-section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.title-icon {
  font-size: 36rpx;
}

.badge-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32rpx;
}

.badge-item {
  text-align: center;
}

.badge-item:hover {
  transform: translateY(-8rpx);
}

.badge-icon {
  width: 144rpx;
  height: 144rpx;
  margin: 0 auto 16rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.badge-icon.unlocked {
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.15);
}

.badge-icon.locked {
  background: #F0F0F0 !important;
  box-shadow: none;
  opacity: 0.4;
}

.badge-icon.locked text {
  opacity: 0.3;
}

.badge-name {
  font-size: 24rpx;
  font-weight: 600;
}

.badge-item.locked .badge-name {
  color: #CCCCCC;
}

.wish-section {
  padding: 0 32rpx 32rpx;
}

.wish-section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wish-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.wish-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  transition: all 0.3s ease;
}

.wish-card:not(.locked):active {
  transform: translateY(-8rpx);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.wish-card.locked {
  opacity: 0.5;
}

.wish-icon {
  width: 112rpx;
  height: 112rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: #fff;
}

.wish-name {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: block;
}

.wish-cost {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 24rpx;
  background: #FFE66D;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #8B6914;
}

.wish-limit {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999;
}

.empty-wishes {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-wishes .empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-wishes .empty-text {
  font-size: 28rpx;
  color: #999;
}
