page {
  background: linear-gradient(180deg, #FFF8E7 0%, #FFE4B5 100%);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 0 0 120rpx;
  box-sizing: border-box;
}

.header-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 32rpx 32rpx;
  background: linear-gradient(180deg, #FF6B35 0%, #FF8C42 100%);
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 53, 0.3);
}

.header-left {
  flex: 1;
}

.page-title {
  font-size: 56rpx;
}

.header-center {
  flex: 3;
  text-align: center;
}

.page-title-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.page-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

.header-right {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.history-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
  transition: all 0.3s ease;
}

.history-btn:active {
  transform: scale(0.95);
}

.history-btn-icon {
  font-size: 36rpx;
}

.timer-section {
  padding: 48rpx 32rpx;
}

.timer-container {
  display: flex;
  justify-content: center;
}

.timer-ring {
  width: 440rpx;
  height: 440rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.timer-progress {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  mask: radial-gradient(farthest-side, transparent calc(100% - 32rpx), #fff calc(100% - 32rpx));
  -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 32rpx), #fff calc(100% - 32rpx));
  transition: background 0.3s ease;
}

.timer-inner {
  position: relative;
  z-index: 1;
  width: 360rpx;
  height: 360rpx;
  background: linear-gradient(135deg, #FFFAF0 0%, #FFF8E7 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.timer-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.timer-time {
  font-size: 88rpx;
  font-weight: bold;
  color: #333;
  font-family: 'Arial Black', sans-serif;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.timer-label {
  font-size: 28rpx;
  color: #666;
  margin-top: 8rpx;
}

.timer-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 48rpx;
  margin-top: 56rpx;
}

.control-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.control-btn:active {
  transform: scale(0.95);
}

.control-btn.primary {
  width: 150rpx;
  height: 150rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 53, 0.5);
}

.control-btn.primary .control-icon {
  color: #fff;
  font-size: 56rpx;
}

.control-btn.secondary {
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.control-icon {
  font-size: 48rpx;
}

.control-btn.secondary .control-icon {
  color: #666;
}

.mode-section {
  padding: 0 32rpx;
  display: flex;
  gap: 24rpx;
}

.mode-card {
  flex: 1;
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx 16rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  border: 4rpx solid transparent;
}

.mode-card:active {
  transform: scale(0.98);
}

.mode-card.active {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 53, 0.4);
  border-color: #FFA726;
}

.mode-emoji {
  font-size: 56rpx;
  display: block;
  margin-bottom: 12rpx;
}

.mode-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.mode-card.active .mode-name {
  color: #fff;
}

.mode-duration {
  font-size: 24rpx;
  color: #999;
}

.mode-card.active .mode-duration {
  color: rgba(255, 255, 255, 0.9);
}

.stats-section {
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: center;
  gap: 32rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.stat-emoji {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B35;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.encourage-section {
  padding: 0 32rpx 40rpx;
}

.encourage-card {
  background: linear-gradient(135deg, #FFF9C4 0%, #FFF59D 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 235, 59, 0.3);
}

.encourage-emoji {
  font-size: 48rpx;
  margin-right: 20rpx;
  animation: wave 1s ease-in-out infinite;
}

@keyframes wave {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-10deg); }
  75% { transform: rotate(10deg); }
}

.encourage-text {
  font-size: 28rpx;
  color: #FF8F00;
  font-weight: 500;
  flex: 1;
}
