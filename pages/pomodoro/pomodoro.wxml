<view class="container">
  <view class="header-section">
    <view class="header-left">
      <text class="page-title">🍅</text>
    </view>
    <view class="header-center">
      <text class="page-title-text">番茄专注</text>
      <text class="page-subtitle">专注学习，快乐成长</text>
    </view>
    <view class="header-right">
      <view class="history-btn" bindtap="goToHistory">
        <text class="history-btn-icon">📋</text>
      </view>
    </view>
  </view>
  
  <view class="timer-section">
    <view class="timer-container">
      <view class="timer-ring">
        <view class="timer-progress" style="background: conic-gradient(#FF6B35 0deg, #FF6B35 {{progress}}deg, #FFE4B5 {{progress}}deg, #FFE4B5 360deg);"></view>
        <view class="timer-inner">
          <text class="timer-emoji">{{timerEmoji}}</text>
          <text class="timer-time">{{formattedTime}}</text>
          <text class="timer-label">{{timerLabel}}</text>
        </view>
      </view>
    </view>
    
    <view class="timer-controls">
      <view class="control-btn secondary" bindtap="resetTimer">
        <text class="control-icon">↻</text>
      </view>
      <view class="control-btn primary" bindtap="toggleTimer">
        <text class="control-icon">{{isRunning ? '❚❚' : '▶'}}</text>
      </view>
      <view class="control-btn secondary complete-btn" bindtap="completeAndGoBack">
        <text class="control-icon">✓</text>
      </view>
    </view>
  </view>
  
  <view class="mode-section">
    <view 
      class="mode-card {{currentMode === 'pomodoro' ? 'active' : ''}}" 
      bindtap="setMode"
      data-mode="pomodoro"
    >
      <text class="mode-emoji">🍅</text>
      <text class="mode-name">专注</text>
      <text class="mode-duration">25分钟</text>
    </view>
    <view 
      class="mode-card {{currentMode === 'shortBreak' ? 'active' : ''}}" 
      bindtap="setMode"
      data-mode="shortBreak"
    >
      <text class="mode-emoji">☕</text>
      <text class="mode-name">短休息</text>
      <text class="mode-duration">5分钟</text>
    </view>
    <view 
      class="mode-card {{currentMode === 'longBreak' ? 'active' : ''}}" 
      bindtap="setMode"
      data-mode="longBreak"
    >
      <text class="mode-emoji">😴</text>
      <text class="mode-name">长休息</text>
      <text class="mode-duration">15分钟</text>
    </view>
  </view>
  
  <view class="stats-section">
    <view class="stat-card">
      <text class="stat-emoji">🍅</text>
      <text class="stat-value">{{todayPomodoros}}</text>
      <text class="stat-label">今日番茄</text>
    </view>
    <view class="stat-card">
      <text class="stat-emoji">⏱️</text>
      <text class="stat-value">{{totalMinutes}}</text>
      <text class="stat-label">专注分钟</text>
    </view>
    <view class="stat-card">
      <text class="stat-emoji">🔥</text>
      <text class="stat-value">{{thisWeekPomodoros}}</text>
      <text class="stat-label">本周番茄</text>
    </view>
  </view>
  
  <view class="encourage-section">
    <view class="encourage-card">
      <text class="encourage-emoji">💪</text>
      <text class="encourage-text">{{encourageText}}</text>
    </view>
  </view>
</view>
