<view class="container">
  <view class="header-section">
    <text class="page-title">🍅 番茄专注</text>
    <text class="page-subtitle">提升专注力，高效学习</text>
  </view>
  
  <view class="timer-section">
    <view class="timer-ring">
      <view class="timer-content">
        <text class="timer-time">{{formattedTime}}</text>
        <text class="timer-label">{{timerLabel}}</text>
      </view>
    </view>
    
    <view class="timer-controls">
      <view class="control-btn secondary" bindtap="resetTimer">
        <text>🔄</text>
      </view>
      <view class="control-btn primary" bindtap="toggleTimer">
        <text>{{isRunning ? '⏸️' : '▶️'}}</text>
      </view>
      <view class="control-btn secondary" bindtap="skipTimer">
        <text>⏭️</text>
      </view>
    </view>
  </view>
  
  <view class="mode-section">
    <view 
      class="mode-item {{currentMode === 'pomodoro' ? 'active' : ''}}" 
      bindtap="setMode"
      data-mode="pomodoro"
    >
      <text class="mode-icon">🍅</text>
      <text class="mode-name">专注</text>
      <text class="mode-duration">25分钟</text>
    </view>
    <view 
      class="mode-item {{currentMode === 'shortBreak' ? 'active' : ''}}" 
      bindtap="setMode"
      data-mode="shortBreak"
    >
      <text class="mode-icon">☕</text>
      <text class="mode-name">短休息</text>
      <text class="mode-duration">5分钟</text>
    </view>
    <view 
      class="mode-item {{currentMode === 'longBreak' ? 'active' : ''}}" 
      bindtap="setMode"
      data-mode="longBreak"
    >
      <text class="mode-icon">😴</text>
      <text class="mode-name">长休息</text>
      <text class="mode-duration">15分钟</text>
    </view>
  </view>
  
  <view class="stats-section">
    <view class="stat-item">
      <text class="stat-icon">🍅</text>
      <text class="stat-value">{{completedPomodoros}}</text>
      <text class="stat-label">完成番茄</text>
    </view>
    <view class="stat-item">
      <text class="stat-icon">⏱️</text>
      <text class="stat-value">{{totalMinutes}}</text>
      <text class="stat-label">累计分钟</text>
    </view>
    <view class="stat-item">
      <text class="stat-icon">🔥</text>
      <text class="stat-value">{{streakDays}}</text>
      <text class="stat-label">连续天数</text>
    </view>
  </view>
  
  <view class="section">
    <view class="section-header">
      <text class="section-title">今日记录</text>
    </view>
    
    <view class="history-list">
      <block wx:for="{{todayHistory}}" wx:key="id">
        <view class="history-item">
          <view class="history-icon">{{item.type === 'pomodoro' ? '🍅' : '☕'}}</view>
          <view class="history-info">
            <text class="history-name">{{item.type === 'pomodoro' ? '专注时间' : '休息时间'}}</text>
            <text class="history-time">{{item.time}}</text>
          </view>
          <view class="history-duration">{{item.duration}}分钟</view>
        </view>
      </block>
      
      <view wx:if="{{todayHistory.length === 0}}" class="empty-state">
        <text class="empty-icon">📝</text>
        <text class="empty-text">今天还没有专注记录</text>
      </view>
    </view>
  </view>
  
</view>