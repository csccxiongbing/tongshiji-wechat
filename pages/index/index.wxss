.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #FFE4E1 0%, #FFB6C1 50%, #FF69B4 100%);
  position: relative;
  overflow: hidden;
}

.hero-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-wrapper {
  position: relative;
  margin-bottom: 40rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF0F5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 60rpx rgba(255, 105, 180, 0.3);
}

.logo-text {
  font-size: 80rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.sparkles {
  position: absolute;
  top: -20rpx;
  left: -20rpx;
  right: -20rpx;
  bottom: -20rpx;
}

.sparkle {
  position: absolute;
  font-size: 32rpx;
  animation: float 2s ease-in-out infinite;
}

.sparkle:nth-child(1) {
  top: 0;
  right: -10rpx;
  animation-delay: 0s;
}

.sparkle:nth-child(2) {
  bottom: 20rpx;
  left: -10rpx;
  animation-delay: 0.5s;
}

.sparkle:nth-child(3) {
  top: 50%;
  right: -30rpx;
  animation-delay: 1s;
}

.title-section {
  animation: fadeInUp 1s ease-out;
}

.main-title {
  font-size: 64rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  text-shadow: 0 4rpx 20rpx rgba(255, 105, 180, 0.3);
}

.sub-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 16rpx;
  display: block;
}

.button-section {
  width: 80%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  animation: fadeInUp 1s ease-out 0.3s both;
}

.btn-primary {
  background: #FFFFFF;
  color: #FF69B4;
  border-radius: 48rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 30rpx rgba(255, 255, 255, 0.4);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 48rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
  backdrop-filter: blur(10px);
}

.footer {
  position: absolute;
  bottom: 60rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

