<view class="container">
  <view class="hero-section">
    <view class="logo-wrapper floating">
      <view class="logo">
        <text class="logo-text">童</text>
      </view>
      <view class="sparkles">
        <text class="sparkle">✨</text>
        <text class="sparkle">⭐</text>
        <text class="sparkle">🌟</text>
      </view>
    </view>
    <view class="title-section">
      <text class="main-title">童时记</text>
      <text class="sub-title">记录成长的每一刻</text>
    </view>
  </view>
  
  <view class="button-section">
    <view class="btn-primary" bindtap="goToLogin">
      <text>登录</text>
    </view>
    <view class="btn-secondary" bindtap="goToRegister">
      <text>注册</text>
    </view>
  </view>
  
  <view class="footer">
    <text class="footer-text">让成长更有仪式感</text>
  </view>
</view>