.custom-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  transition: all 0.3s ease;
}

.tab-icon {
  font-size: 44rpx;
  margin-bottom: 6rpx;
  opacity: 0.6;
  transition: all 0.3s ease;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
  transition: all 0.3s ease;
}

.tab-item.active .tab-icon {
  opacity: 1;
  transform: scale(1.1);
}

.tab-item.active .tab-text {
  color: #FF69B4;
  font-weight: bold;
}